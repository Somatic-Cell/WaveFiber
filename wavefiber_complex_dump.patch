+static void write_float_vector_binary(const std::string &filename, const hostFvec &values) {
+  std::ofstream out(filename, std::ios::out | std::ios::binary);
+  if (!out) {
+    std::cerr << "Failed to open " << filename << " for writing." << std::endl;
+    std::exit(EXIT_FAILURE);
+  }
+  if (!values.empty()) {
+    out.write(reinterpret_cast<const char *>(&values[0]), sizeof(float) * values.size());
+  }
+}
+
+static void write_float2_vector_binary(const std::string &filename, const hostf2vec &values) {
+  std::ofstream out(filename, std::ios::out | std::ios::binary);
+  if (!out) {
+    std::cerr << "Failed to open " << filename << " for writing." << std::endl;
+    std::exit(EXIT_FAILURE);
+  }
+  if (!values.empty()) {
+    out.write(reinterpret_cast<const char *>(&values[0]), sizeof(float2) * values.size());
+  }
+}
+
+static void write_complex_dump_metadata(const std::string &filename,
+                                        int fiberindex,
+                                        int lambdaindex,
+                                        float wavelength_nm,
+                                        int thetaiindex,
+                                        float thetai,
+                                        int phiiindex,
+                                        float phii,
+                                        char mode,
+                                        int max_depth,
+                                        int startindex,
+                                        int endindex,
+                                        int thetaonum,
+                                        int phionum,
+                                        int obnum,
+                                        float thetastartoffset,
+                                        float Z0_value) {
+  std::ofstream meta(filename);
+  if (!meta) {
+    std::cerr << "Failed to open " << filename << " for writing." << std::endl;
+    std::exit(EXIT_FAILURE);
+  }
+
+  meta << std::setprecision(10);
+  meta << "format_version 1\n";
+  meta << "complex_storage interleaved_float32_real_imag\n";
+  meta << "direction_storage interleaved_float32_xyz\n";
+  meta << "grid_layout theta_major_phi_minor\n";
+  meta << "fiberindex " << fiberindex << "\n";
+  meta << "lambdaindex " << lambdaindex << "\n";
+  meta << "wavelength_nm " << wavelength_nm << "\n";
+  meta << "thetaiindex " << thetaiindex << "\n";
+  meta << "thetai_rad " << thetai << "\n";
+  meta << "phiiindex " << phiiindex << "\n";
+  meta << "phii_rad " << phii << "\n";
+  meta << "mode " << mode << "\n";
+  meta << "max_depth " << max_depth << "\n";
+  meta << "startindex " << startindex << "\n";
+  meta << "endindex " << endindex << "\n";
+  meta << "thetaonum " << thetaonum << "\n";
+  meta << "phionum " << phionum << "\n";
+  meta << "obnum " << obnum << "\n";
+  meta << "thetastartoffset_rad " << thetastartoffset << "\n";
+  meta << "Z0 " << Z0_value << "\n";
+}
 
